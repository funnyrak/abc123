# Supabase project settings (Project Settings > API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-only, never expose to the client.
# Used by the delay-check cron job (system job, bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret Vercel Cron sends as "Authorization: Bearer <value>" to
# /api/cron/check-delays. Generate with `openssl rand -base64 32`.
CRON_SECRET=

# Public site URL, used to build mentor claim-invite links
# (/admin/mentors/unclaimed). Set to https://www.mentoring-usg.kr in
# production; localhost is fine for local dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
